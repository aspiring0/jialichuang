# ============================================
# Multi-Agent Data Analysis Assistant
# Environment Configuration Template
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# Application Settings
# ============================================
APP_NAME=Multi-Agent Data Analysis Assistant
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# ============================================
# Server Configuration
# ============================================
HOST=0.0.0.0
PORT=8000

# ============================================
# PostgreSQL Database
# ============================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=multi_agent_db
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# ============================================
# RabbitMQ Configuration
# ============================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:${RABBITMQ_PORT}//

# ============================================
# MinIO (S3 Compatible Storage)
# ============================================
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=data-analysis
S3_ENDPOINT_URL=http://${MINIO_HOST}:${MINIO_PORT}

# ============================================
# LLM API Configuration
# ============================================
# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview

# Anthropic Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Zhipu AI Configuration (智谱AI)
ZHIPU_API_KEY=your-zhipu-api-key-here
ZHIPU_MODEL=glm-4

# Default LLM Provider (openai, anthropic, or zhipu)
DEFAULT_LLM_PROVIDER=zhipu

# ============================================
# Sandbox Configuration
# ============================================
SANDBOX_TIMEOUT=30
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_CPU_LIMIT=1

# ============================================
# Celery Configuration
# ============================================
CELERY_BROKER_URL=${RABBITMQ_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# ============================================
# Monitoring Configuration
# ============================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
ENABLE_METRICS=true

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json